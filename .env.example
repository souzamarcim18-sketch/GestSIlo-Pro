# Supabase Configuration
# Configure these in AI Studio Settings > Environment Variables
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ⚠️ SEGURANÇA CRÍTICA: A SERVICE_ROLE_KEY bypassa completamente o RLS do Supabase.
# NUNCA commite esta variável. NUNCA exponha em logs, respostas de API ou client-side.
# Usada exclusivamente em: app/api/cron/alertas/route.ts (Vercel Cron, server-side only).
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis Configuration (Rate Limiting)
# Required for authentication rate limiting
# Get these from https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Site URL for redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL pública da aplicação (ex: https://gestsilo.com ou http://localhost:3000)
NEXT_PUBLIC_APP_URL=

# Email do consultor que recebe notificações de agendamento
NEXT_PUBLIC_CONSULTOR_EMAIL=

# Chave HS256 256 bits — usada para tokens de link mágico de assessoria
# Gerar com: openssl rand -hex 32
JWT_SECRET=

# Sentry Error Monitoring (Optional)
# Get your DSN from https://sentry.io after creating a project
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Supabase Type Generation
# Get your project ID from https://app.supabase.com/projects
# Run: npm run db:types to generate TypeScript types automatically
SUPABASE_PROJECT_ID=

# Resend — envio de emails (assessoria, convites, alertas)
RESEND_API_KEY=

# Segredo para autenticar o Vercel Cron Job na API route POST /api/cron/alertas
# Gerar com: openssl rand -hex 32
# Configurar também em: Vercel Dashboard → Settings → Environment Variables
CRON_SECRET=
